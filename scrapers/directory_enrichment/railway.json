{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt"
  },
  "deploy": {
    "startCommand": "python -m scrapers.directory_enrichment.run_directory_enrichment --directory all --vendor-type all --max-runtime-seconds 14400",
    "restartPolicyType": "NEVER"
  }
}
