{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "scrapers/llm_data_verifier/Dockerfile"
  },
  "deploy": {
    "startCommand": "python -m scrapers.llm_data_verifier.run_verifier --vendor-type all",
    "restartPolicyType": "NEVER",
    "numReplicas": 1
  }
}
