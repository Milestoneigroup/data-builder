# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/

# Environment and secrets (never commit local keys)
.env
.env.local
.env.*.local
env.local

# IDE
.idea/
.vscode/
*.swp
*.swo

# Local data drops (Excel, CSV, exports) — keep folder only
data/*
!data/.gitkeep
!data/ew_celebrants.csv
!data/seed_weather_test_cells.json
!data/chain_seeds/
!data/chain_seeds/*.json

# Log files (keep logs/ directory via .gitkeep)
logs/*
!logs/.gitkeep

# LLM verifier I/O (sensitive contact data)
scrapers/llm_data_verifier/inputs/*
!scrapers/llm_data_verifier/inputs/.gitkeep
scrapers/llm_data_verifier/outputs/*
!scrapers/llm_data_verifier/outputs/.gitkeep

# Logs and temp
*.log
tmp/
.temp/

# pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/
